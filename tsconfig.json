{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@simplapp/domain": ["packages/domain/src"],
      "@simplapp/interfaces": ["packages/interfaces/src"],
      "@simplapp/ui": ["packages/ui/src"],
      "@domain/*": ["packages/domain/src/*"],
      "@interfaces/*": ["packages/interfaces/src/*"],
      "@hooks/*": ["packages/interfaces/src/hooks/*"],
      "@ui/*": ["packages/ui/src/*"]
    }
  },
  "files": [],
  "references": [
    { "path": "./packages/domain" },
    { "path": "./packages/interfaces" },
    { "path": "./packages/ui" },
    { "path": "./apps/web" }
  ]
}
