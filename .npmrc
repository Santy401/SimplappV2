# Hoist Prisma so all workspaces share a single instance.
# Required because Prisma generates typed code at build time and
# pnpm's strict isolation would otherwise create multiple disconnected instances.
shamefully-hoist=true

# Allow prisma to run its postinstall scripts, which generate the .prisma/client
# directory with all the TypeScript types (PrismaClient, enums, etc).
# Without this, pnpm blocks prisma's build scripts and the generated types
# never appear, causing "no exported member 'PrismaClient'" errors in CI.
auto-install-peers=true
