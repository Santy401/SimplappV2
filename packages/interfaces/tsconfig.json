{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "outDir": "./dist",
    "rootDir": "../../",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "paths": {
      "@/*": [
        "../../apps/web/*"
      ],
      "@domain/*": [
        "../domain/src/*"
      ],
      "@interfaces/*": [
        "./*"
      ],
      "@web/*": [
        "../../apps/web/app/*"
      ],
      "@ui/*": [
        "../ui/src/*"
      ],
      "@hooks/*": [
        "./src/hooks/*"
      ],
      "@prisma/client": [
        "../../apps/web/node_modules/@prisma/client"
      ]
    }
  },
  "include": [
    "src/**/*",
    "lib/**/*",
    "data/**/*",
    "../domain/src/**/*",
    "../ui/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "references": [
    {
      "path": "../domain"
    }
  ]
}