# ··················· # Environment variables Example # ··················· #
DATABASE_URL=" EXAMPLE "
DIRECT_URL=" EXAMPLE "
JWT_SECRET=" EXAMPLE "
JWT_REFRESH_SECRET=" EXAMPLE "
NEXT_PUBLIC_API_URL=" EXAMPLE "

# ── Domain Configuration (production only) ──
# Root domain (sin punto inicial) → usado por el middleware para routing
NEXT_PUBLIC_ROOT_DOMAIN="simplapp.com"
# Cookie domain (con punto inicial) → permite cookies cross-subdomain
COOKIE_DOMAIN=".simplapp.com"
