// ===========================================
// 👤 AUTH DOMAIN
// Models: User, UserCompany, RefreshToken,
//         PasswordResetToken, EmailVerificationToken
// Enums:  UserRole
// ===========================================

// --- ENUMS ---

/// Roles que puede tener un usuario dentro de una empresa
enum UserRole {
  OWNER // Dueño de la empresa — acceso total
  ADMIN // Administrador — acceso casi total
  ACCOUNTANT // Contador — acceso a facturación y reportes
  EMPLOYEE // Empleado — acceso limitado
}

// --- MODELS ---

/// Usuario autenticado de la plataforma.
/// Un usuario puede pertenecer a múltiples empresas (UserCompany).
model User {
  id          String @id @default(uuid())
  email       String @unique
  name        String
  password    String
  typeAccount String
  country     String

  onboardingCompleted Boolean @default(false)
  emailVerified       Boolean @default(false)

  // Profile settings
  profileLogo   String?
  language      String? @default("es")
  timezone      String? @default("America/Bogota")
  lastCompanyId String // ID de la última empresa seleccionada por el usuario

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  companies               UserCompany[]
  bills                   Bill[]
  refreshTokens           RefreshToken[]
  activityLogs            ActivityLog[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notifications           Notification[]
}

/// Tabla pivot que une Usuario ↔ Empresa con un rol específico.
/// Un usuario puede ser OWNER en una empresa y EMPLOYEE en otra.
model UserCompany {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(EMPLOYEE)

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}

/// Token JWT de refresco para mantener sesiones activas.
/// Se invalida automáticamente al expirar o hacer logout.
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

/// Token de un solo uso para recuperación de contraseña.
model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  used      Boolean  @default(false) // Evitar reutilización del token
  createdAt DateTime @default(now())
  ipAddress String? // Auditoría: quién solicitó el reset

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

/// Token de un solo uso para verificación de correo electrónico.
model EmailVerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ===========================================
// ⚙️  BASE CONFIGURATION
// Generator + Datasource
// ===========================================

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
  // Output path is relative to THIS file (prisma/schema/base.prisma)
  // so we go up one level to reach prisma/src/generated/prisma
  output     = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===========================================
// 🧾 BILLING DOMAIN
// Models: Bill, BillItem, Payment, BankAccount
// Enums:  BillStatus, PaymentMethod, BankAccountType, DianStatus
// ===========================================

// --- ENUMS ---

/// Estado en la DIAN (Facturación Electrónica)
enum DianStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
}

/// Estado comercial de una factura
enum BillStatus {
  DRAFT // Borrador (no oficial)
  ISSUED // Emitida / Timbrada
  PAID // Pagada en su totalidad
  PARTIALLY_PAID // Con abonos
  CANCELLED // Anulada
  TO_PAY // Por pagar (Crédito)
}

/// Método o medio de pago (estandarizado)
enum PaymentMethod {
  UNDEFINED
  CASH
  CREDIT_CARD
  DEBIT_CARD
  TRANSFER
  CHECK
  DEPOSIT
  OTHER
  CREDIT
}

/// Clasificación de la cuenta financiera
enum BankAccountType {
  CASH // Caja menor / Efectivo
  BANK // Cuenta bancaria (Ahorros, Corriente)
  CREDIT_CARD // Tarjeta de crédito corporativa
  OTHER // Otros medios (Pasarelas, etc.)
}

// --- MODELS ---

/// Factura de venta. Conecta transacción financiera, inventario y DIAN.
model Bill {
  id          String  @id @default(uuid())
  userId      String
  clientId    String
  storeId     String
  listPriceId String?
  sellerId    String?
  companyId   String

  // Relaciones Base
  user    User    @relation(fields: [userId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  // --- 1. Control Legal y Numeración ---
  prefix      String? @default("") // Ejemplo: "SETT" o "FV"
  number      Int
  legalNumber String? // El consecutivo final autorizado

  // --- 2. Estados y Fechas ---
  status        BillStatus    @default(DRAFT)
  paymentMethod PaymentMethod @default(CASH)

  date    DateTime @default(now())
  dueDate DateTime

  // --- 3. Totales (Cálculos guardados para snapshot) ---
  subtotal      Decimal @default(0)
  taxTotal      Decimal @default(0)
  discountTotal Decimal @default(0)
  total         Decimal @default(0)
  balance       Decimal @default(0)

  // --- 4. Snapshot (Datos inmutables al momento de facturar) ---
  clientName           String?
  clientIdentification String?
  clientAddress        String?
  clientPhone          String?
  clientEmail          String?
  notes                String?

  // --- 5. Facturación Electrónica DIAN ---
  cufe           String? // Código único de factura electrónica
  dianStatus     DianStatus?
  dianResponse   String? // Respuesta en bruto de la DIAN si aplica
  xml            String? // Contenido XML firmado
  pdfUrl         String? // Archivo generado
  sentAt         DateTime?
  acceptedAt     DateTime?
  rejectedReason String?

  items    BillItem[]
  payments Payment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([companyId, prefix, number])
  @@index([companyId])
  @@index([createdAt])
  @@index([status])
  @@index([deletedAt])
}

/// Detalle individual de una factura (línea de producto o servicio).
model BillItem {
  id        String @id @default(uuid())
  billId    String
  productId String
  quantity  Int

  price    Decimal
  subtotal Decimal

  taxRate   Decimal @default(0)
  taxAmount Decimal @default(0)
  discount  Decimal @default(0)
  total     Decimal

  // Snapshot del producto
  productName String?
  productCode String?

  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

/// Recibo de pago asociado a una factura en específico.
model Payment {
  id String @id @default(uuid())

  billId String
  bill   Bill   @relation(fields: [billId], references: [id])

  accountId String?
  account   BankAccount? @relation(fields: [accountId], references: [id])

  amount Decimal
  method PaymentMethod
  date   DateTime      @default(now())

  receiptNumber String?
  notes         String?
}

/// Cuenta bancaria, caja u otra entidad para el manejo de tesorería y recaudo.
model BankAccount {
  id        String  @id @default(uuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name        String
  type        BankAccountType @default(CASH)
  currency    String          @default("COP")
  description String?

  balance Decimal @default(0)
  active  Boolean @default(true)

  payments Payment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([deletedAt])
}

// ===========================================
// 🏢 COMPANY DOMAIN
// Models: Company, Subscription
// Enums:  OrganizationType, VatCondition,
//         PlanType, SubscriptionStatus
// ===========================================

// --- ENUMS ---

/// Tipo de organización — aplica tanto a empresas como a clientes
enum OrganizationType {
  NATURAL_PERSON // Persona natural
  PERSON_JURIDIC // Persona jurídica
  LEGAL_ENTITY // Entidad legal
  COMPANY // Empresa genérica
}

/// Condición frente al IVA (para facturación DIAN)
enum VatCondition {
  RESPONSABLE // Responsable del IVA
  NO_RESPONSABLE // No responsable del IVA
  EXENTO // Exento del IVA
  SIMPLIFIED_REGIME // Régimen simplificado
}

/// Plan de suscripción de la empresa en la plataforma
enum PlanType {
  FREE // Plan gratuito con límites
  PRO // Plan profesional
  ENTERPRISE // Plan empresarial sin límites
}

/// Estado actual de la suscripción
enum SubscriptionStatus {
  ACTIVE // Suscripción activa y al día
  CANCELED // Cancelada por el usuario
  PAST_DUE // Vencida (pago pendiente)
}

// --- MODELS ---

/// Entidad central del sistema. Cada empresa tiene su propio
/// conjunto de clientes, productos, facturas, etc. (multitenant).
model Company {
  id String @id @default(uuid())

  companyName      String           @default("")
  logoUrl          String? // URL del logo de la empresa
  accountId        String?          @default("")
  commercialName   String?          @default("")
  organizationType OrganizationType @default(COMPANY)
  vatCondition     VatCondition     @default(SIMPLIFIED_REGIME)

  identificationNumber String  @default("")
  verificationDigit    String? @default("")

  lastAccountingClose    DateTime?
  economicActivity       String?   @default("")
  industryAndCommerceTax Boolean   @default(false)

  // Dirección
  address      String  @default("")
  department   String? @default("")
  municipality String? @default("")
  postalCode   String? @default("")

  // Contacto
  phone   String? @default("")
  email   String? @default("")
  website String? @default("")

  // Configuración de facturación
  currency             String? @default("COP")
  invoicePrefix        String? @default("FAC")
  invoiceInitialNumber Int?    @default(1)
  defaultTax           String? @default("19")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  users              UserCompany[]
  stores             Store[]
  clients            Client[]
  sellers            Seller[]
  products           Product[]
  bills              Bill[]
  bankAccounts       BankAccount[]
  categories         CategoryProduct[]
  productAccountings ProductAccounting[]
  listPrices         ListPrice[]
  activityLogs       ActivityLog[]
  notifications      Notification[]
  subscription       Subscription?

  @@index([deletedAt])
}

/// Suscripción activa de una empresa (relación 1:1 con Company).
model Subscription {
  id        String             @id @default(uuid())
  companyId String             @unique
  plan      PlanType           @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime?
  stripeId  String? // ID de Stripe para gestión de pagos

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ===========================================
// 🤝 CRM DOMAIN
// Models: Client, Seller
// Enums:  IdentificationType
// ===========================================

// --- ENUMS ---

/// Tipo de documento de identidad
enum IdentificationType {
  CITIZEN_ID // Cédula de ciudadanía
  NIT // Número de Identificación Tributaria
  PASSPORT // Pasaporte
  TAX_ID // Identificador fiscal extranjero
  FOREIGN_ID // Cédula de extranjería
}

// --- MODELS ---

/// Cliente de una empresa.
/// Puede ser una persona natural o jurídica.
model Client {
  id String @id @default(uuid())

  organizationType OrganizationType
  firstLastName    String
  secondLastName   String?
  firstName        String
  otherNames       String?
  commercialName   String?
  code             String?

  identificationType   IdentificationType
  identificationNumber String

  email        String?
  includeCcBcc Boolean @default(false)
  phone        String?

  // Localidad
  country      String
  department   String?
  municipality String?
  postalCode   String?
  address      String?

  // Configuraciones adicionales
  is_supplier  Boolean @default(false)
  it_branches  Boolean @default(false)
  observations String?

  companyId String
  company   Company? @relation(fields: [companyId], references: [id])

  bills Bill[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([companyId, identificationNumber])
  @@index([companyId])
  @@index([identificationNumber])
  @@index([deletedAt])
}

/// Vendedor asociado a una empresa.
/// Se usa para asignar comisiones en las facturas.
model Seller {
  id             String   @id @default(uuid())
  name           String
  identification String?
  observation    String?
  companyId      String?
  company        Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([deletedAt])
}

// ===========================================
// 🏬 INVENTORY DOMAIN
// Models: Store, Product, CategoryProduct, ProductImage,
//         ProductAccounting, InventoryMovement,
//         ListPrice, ProductPrice
// Enums:  ItemType, MovementType, TypePrice, UnitOfMeansureList
// ===========================================

// --- ENUMS ---

/// Tipo de artículo en el inventario o facturación
enum ItemType {
  PRODUCT // Producto físico
  SERVICE // Servicio prestado
  COMBO // Agrupación de productos/servicios
  VARIANT // Variante de un producto (ej. talla, color)
}

/// Tipo de movimiento en el kárdex (inventario)
enum MovementType {
  IN // Entrada de mercancía
  OUT // Salida de mercancía
  ADJUSTMENT // Ajuste manual de inventario
  TRANSFER // Transferencia entre bodegas
}

/// Configuración para una lista de precios
enum TypePrice {
  VALOR // Monto fijo
  PORCENTAJE // Porcentaje sobre el costo/base
}

/// Unidades de medida estandarizadas por la DIAN
enum UnitOfMeansureList {
  UNIDAD
  PAR
  CAJA
  BOTELLA
  CENTIMETRO
  CENTIMETRO_CUADRADO
  METRO_CUADRADO
  PULGADA
  MILILITRO
  LITRO
  GALON
  METRO_CUBICO
  GRAMO
  KILOGRAMO
  TONELADA
  LIBRA
  HORA
  MINUTO
  DIA
}

// --- MODELS ---

/// Bodega o sucursal de inventario.
model Store {
  id          String  @id @default(uuid())
  name        String
  address     String?
  observation String?

  companyId String
  company   Company? @relation(fields: [companyId], references: [id])

  bills              Bill[]
  inventoryMovements InventoryMovement[]
  products           Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([deletedAt])
}

/// Categoría para agrupar productos y servicios.
model CategoryProduct {
  id          String @id @default(uuid())
  name        String
  description String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  products Product[]

  @@index([companyId])
}

/// Producto o servicio ofrecido por la empresa.
model Product {
  id String @id @default(uuid())

  name        String
  description String?
  reference   String?
  code        String? @unique

  type ItemType
  unit UnitOfMeansureList

  taxRate String

  cost       Decimal?
  basePrice  Decimal?
  finalPrice Decimal?

  trackStock         Boolean @default(true)
  allowNegativeStock Boolean @default(false)
  active             Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  categoryProductId String
  category          CategoryProduct @relation(fields: [categoryProductId], references: [id])

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  images             ProductImage[]
  prices             ProductPrice[]
  accountings        ProductAccounting[]
  inventoryMovements InventoryMovement[]
  billItems          BillItem[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([companyId])
  @@index([code])
  @@index([deletedAt])
  @@index([storeId])
}

/// Imágenes asociadas a un producto.
model ProductImage {
  id  String @id @default(uuid())
  url String

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

/// Configuración contable de un producto específico.
model ProductAccounting {
  id String @id @default(uuid())

  productId String
  companyId String

  incomeAccount    String
  inventoryAccount String
  costAccount      String

  product Product @relation(fields: [productId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([productId, companyId])
}

/// Registro de movimientos de inventario (Kárdex).
model InventoryMovement {
  id String @id @default(uuid())

  productId String
  storeId   String

  quantity Int
  type     MovementType

  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
}

/// Lista de precios (ej. Mayorista, Minorista).
model ListPrice {
  id String @id @default(uuid())

  name        String
  type        TypePrice @default(VALOR)
  description String?
  percentage  String?

  companyId String
  company   Company? @relation(fields: [companyId], references: [id])

  prices ProductPrice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Precio asignado a un producto en una lista de precios específica.
model ProductPrice {
  id String @id @default(uuid())

  productId   String
  listPriceId String

  basePrice Decimal
  value     Decimal

  product   Product   @relation(fields: [productId], references: [id])
  listPrice ListPrice @relation(fields: [listPriceId], references: [id])
}

// ===========================================
// 📊 SYSTEM DOMAIN
// Models: ActivityLog, Notification
// Enums:  NotificationType
// ===========================================

// --- ENUMS ---

/// Nivel o tipo de notificación en el sistema.
enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  DIAN_REJECTED // Específico para errores críticos de DIAN
  BILL_OVERDUE // Específico para facturas vencidas
}

// --- MODELS ---

/// Log de auditoría para trazar los cambios críticos
/// (qué cambió, quién lo hizo, cuándo, IP, etc.)
model ActivityLog {
  id        String  @id @default(uuid())
  companyId String
  userId    String?

  action     String // CREATE, UPDATE, DELETE, SEND, CANCEL
  entityType String // Bill, Client, Product, etc.
  entityId   String

  changes   Json? // Objeto con 'before' y 'after' o diff
  metadata  Json? // Otros datos contextuales útiles
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

/// Notificación en la campana (in-app notification).
model Notification {
  id        String @id @default(uuid())
  userId    String
  companyId String

  title    String
  message  String
  type     NotificationType @default(INFO)
  read     Boolean          @default(false)
  archived Boolean          @default(false)
  link     String? // URL opcional al recurso relacionado

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
}
