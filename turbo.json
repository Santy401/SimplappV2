{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "tsconfig.base.json",
    "pnpm-lock.yaml"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ],
      "inputs": [
        "**/*",
        "!.next/**",
        "!node_modules/**"
      ]
    },
    "check-types": {
      "dependsOn": [
        "^check-types"
      ],
      "inputs": [
        "**/*.ts",
        "**/*.tsx",
        "tsconfig.json"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
