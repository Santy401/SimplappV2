{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "tsconfig.base.json",
    "pnpm-lock.yaml",
    ".env"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "src/**",
        "app/**",
        "lib/**",
        "public/**",
        "styles/**",
        "components/**",
        "prisma/schema.prisma",
        "package.json",
        "tsconfig.json",
        "next.config.js",
        "next.config.ts",
        "tailwind.config.js",
        "postcss.config.mjs"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ]
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "inputs": [
        "src/**",
        "app/**",
        "lib/**",
        "components/**",
        "package.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
